# Copy this file to .env and fill in your values.
# Never commit .env - it contains secrets.

# PostgreSQL (for DB mode)
PG_USER="<PostgreSQL username>"
PG_PASSWORD="<PostgreSQL password>"
PG_HOST="<PostgreSQL host>"
PG_PORT="<PostgreSQL port>"
PG_DATABASE="<PostgreSQL database name>"

# Command authentication - shared secret for HMAC-SHA256
# Use a 32-byte hex string (64 hex chars), e.g. from: python3 -c "import secrets; print(secrets.token_hex(32))"
AUTH_KEY="<HMAC-SHA256 shared secret>"
