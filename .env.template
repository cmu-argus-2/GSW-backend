# Copy from .env.example and fill in your values.
# This file is gitignored - never commit secrets.

# PostgreSQL (for DB mode)
PG_USER=
PG_PASSWORD=
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=heartbeats

# Command authentication - shared secret for HMAC-SHA256 (32-byte key as 64 hex chars)
# You can generate a random key using: python -c "import secrets; print(secrets.token_hex(32))"
AUTH_KEY="YOUR_AUTH_KEY_HERE"
